    """Fetch recent bot-generated alerts."""
    with get_connection() as conn:
        cursor = conn.cursor()
        cursor.execute(
            "SELECT * FROM alert_logs WHERE user_id = 0 ORDER BY triggered_at DESC LIMIT ?",
            (limit,)
        )
        return [dict(row) for row in cursor.fetchall()]

